{
  "name": "mrak-os-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate-types": "npx openapi-typescript ./openapi.yaml -o ./src/shared/api/generated/schema.ts",
