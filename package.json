{
  "name": "mrak-os-monorepo",
  "version": "1.0.0",
  "description": "Monorepo for MRAK-OS backend and frontend",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "python -m uvicorn src.interfaces.http.app:app --reload --port 8000",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
